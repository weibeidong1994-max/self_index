---
interface Props {
  title: string;
  description: string;
  status: '规划中' | '进行中' | '已完成';
  slug: string;
}

const { title, description, status, slug } = Astro.props;

const statusConfig = {
  '已完成': {
    color: 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200',
    dot: '🟢',
  },
  '进行中': {
    color: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200',
    dot: '🟡',
  },
  '规划中': {
    color: 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200',
    dot: '⚪',
  },
};

const cfg = statusConfig[status];
---

<a
  href={`/roadmap/${slug}`}
  class="block rounded-xl p-6 shadow-md hover:shadow-xl transition-shadow duration-300 bg-white dark:bg-gray-800"
>
  <div class="flex items-center justify-between mb-3 gap-4">
    <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
      {title}
    </h3>
    <span class={`text-xs px-2 py-1 rounded-full shrink-0 ${cfg.color}`}>
      {cfg.dot} {status}
    </span>
  </div>
  <p class="text-gray-600 dark:text-gray-300 text-sm line-clamp-3">
    {description}
  </p>
</a>
